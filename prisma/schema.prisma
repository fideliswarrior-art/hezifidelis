// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// LIGA DE BASQUETE — SCHEMA PRISMA v1.0 (COMPLETO)
// Referências: Overtime Elite (OTE), Kings League Brasil,
//              FIBA 3x3 (play.fiba3x3.com), High Company BR
//
// SEÇÕES:
//   1.  Enums (agrupados por domínio)
//   2.  Usuários e RBAC
//   3.  Notificações
//   4.  Estrutura da Liga (Season → Split → Phase → Group → PlayoffSeries)
//   5.  Times
//   6.  Jogadores
//   7.  Draft
//   8.  Locais (Venue)
//   9.  Inscrição em Eventos
//   10. Partidas
//   11. Play-by-play / Scorebook do Mesário
//   12. Estatísticas
//   13. Classificação
//   14. Premiações
//   15. Ação Social e Beneficência
//   16. Conteúdo e Notícias
//   17. Loja e E-Commerce
//   18. Ingressos / Tickets
//   19. Mídia e Álbuns
//   20. Patrocinadores
//   21. Auditoria e Logs
//   22. Privacidade e LGPD (Onda 2 - E2.6)
// =============================================================================

// =============================================================================
// SEÇÃO 1: ENUMS
// Agrupados por domínio para facilitar a leitura e manutenção.
// =============================================================================

// ---------------------------------------------------------------------------
// 1.1 Controle de Acesso
// ---------------------------------------------------------------------------

// [T] SCOREKEEPER e REFEREE adicionados para papéis operacionais em eventos.
// SCOREKEEPER: acessa o scorebook digital e lança estatísticas ao vivo.
// REFEREE: registra faltas técnicas e eventos disciplinares.
enum Role {
  USER // Torcedor / cliente da loja
  EDITOR // Jornalista / criador de conteúdo
  MODERATOR // Modera comentários e conteúdo publicado
  SCOREKEEPER // Mesário: lança estatísticas ao vivo em torneios oficiais
  REFEREE // Árbitro: registra faltas técnicas e eventos disciplinares
  ADMIN // Gerente da liga / painel administrativo
  SUPER_ADMIN // Acesso irrestrito ao sistema
}

// [S] Novos tipos adicionados para os fluxos de votação, campanhas e premiação.
enum NotificationType {
  MATCH_RESULT // Resultado de uma partida finalizada
  MATCH_REMINDER // Lembrete de jogo próximo (ex: 30min antes)
  NEWS // Nova notícia publicada
  TICKET_AVAILABLE // Ingressos disponíveis para venda
  DRAFT_LIVE // Draft acontecendo ao vivo agora
  SYSTEM // Comunicado geral do sistema
  MVP_VOTE_OPEN // [S] Votação de MVP aberta no Instagram
  CAMPAIGN_UPDATE // [S] Atualização de progresso de campanha beneficente
  EVENT_REGISTRATION_STATUS // [S] Inscrição aprovada, rejeitada ou lista de espera
  AWARD_RECEIVED // [S] Jogador ou time recebeu um prêmio da temporada
}

// ---------------------------------------------------------------------------
// 1.2 Estrutura da Liga
// ---------------------------------------------------------------------------

// [R] Novos tipos para torneios comunitários e eventos beneficentes.
enum SplitType {
  WINTER_CUP // Copa de Inverno
  SUMMER_LEAGUE // Liga Principal de Verão
  PLAYOFFS // Fase de eliminatória
  FRIENDLY // Amistoso / pré-temporada
  COMMUNITY_TOURNAMENT // [R] Torneio comunitário / pelada organizada
  CHARITY_EVENT // [R] Evento beneficente (arrecadação de fundos)
  THREES_TOURNAMENT // [R] Torneio exclusivo de 3x3
}

enum PhaseType {
  GROUP_STAGE // Fase de grupos (round robin)
  ROUND_OF_16 // Oitavas de final
  QUARTER_FINAL // Quartas de final
  SEMI_FINAL // Semifinal
  THIRD_PLACE // Disputa de 3º lugar
  FINAL // Grande Final
}

enum SeriesStatus {
  SCHEDULED // Série agendada, ainda não iniciou
  IN_PROGRESS // Série em andamento
  FINISHED // Série concluída (winnerId preenchido)
}

// ---------------------------------------------------------------------------
// 1.3 Modalidade de Jogo (NOVO)
// ---------------------------------------------------------------------------

// [A] Enum central para o projeto: suporta todas as modalidades de basquete
// que a liga organiza — de 1x1 até 5x5 (basquete tradicional).
// REGRA: Match.format deve ser consistente com o Split.defaultFormat do split pai.
// O backend deve validar isso ao criar partidas.
enum GameFormat {
  ONE_ON_ONE // 1x1 — duelo individual
  TWO_ON_TWO // 2x2 — duplas
  THREE_ON_THREE // 3x3 — regras FIBA 3x3 (10min, 21pts, sem linha de 3)
  FIVE_ON_FIVE // 5x5 — basquete tradicional (4 quartos de 10min)
}

// ---------------------------------------------------------------------------
// 1.4 Partidas e Árbitros
// ---------------------------------------------------------------------------

enum MatchStatus {
  SCHEDULED // Agendada — data e hora definidas
  LIVE // Em andamento — placar sendo atualizado em tempo real
  FINISHED // Encerrada — resultado definitivo
  CANCELED // Cancelada — não será realizada
  POSTPONED // Adiada — nova data ainda não definida
  FORFEIT // W.O. — ausência formal de um dos times antes do jogo
}

// Como a partida foi encerrada (preenchido apenas quando status = FINISHED).
enum WinType {
  REGULATION // Tempo normal
  WIN_BEFORE_LIMIT // Atingiu 21 pts antes do tempo (regra 3x3)
  OVERTIME // Prorrogação
  FORFEIT // Vitória por W.O. (adversário não compareceu ou foi desclassificado)
}

// [D] Papéis dos responsáveis vinculados à partida.
enum OfficialRole {
  REFEREE // Árbitro principal
  SCOREKEEPER // Mesário: responsável pelo scorebook digital
  TIMEKEEPER // Cronometrista
  VOLUNTEER // Voluntário de apoio geral
}

// [E] Tipos de evento registrados no play-by-play pelo mesário.
// Cada MatchEvent é um lance atômico da partida, fonte de verdade para MatchStat.
enum MatchEventType {
  // --- Arremessos ---
  TWO_POINT_MADE // Bandeja ou arremesso de 2pts convertido
  TWO_POINT_MISSED // Arremesso de 2pts errado
  THREE_POINT_MADE // Arremesso de 3pts convertido
  THREE_POINT_MISSED // Arremesso de 3pts errado
  FREE_THROW_MADE // Lance livre convertido
  FREE_THROW_MISSED // Lance livre errado

  // --- Rebotes ---
  REBOUND_OFFENSIVE // Rebote ofensivo
  REBOUND_DEFENSIVE // Rebote defensivo

  // --- Defesa ---
  STEAL // Roubo de bola
  BLOCK // Bloqueio / toco

  // --- Erros ---
  TURNOVER // Perda de bola / erro

  // --- Faltas ---
  PERSONAL_FOUL // Falta pessoal
  TECHNICAL_FOUL // Falta técnica
  FLAGRANT_FOUL // Falta flagrante

  // --- Controle de jogo (teamSide e playerId são null nestes) ---
  TIMEOUT_CALLED // Tempo-técnico solicitado
  SUBSTITUTION_IN // Jogador entra em quadra
  SUBSTITUTION_OUT // Jogador sai de quadra
  PERIOD_START // Início do quarto/período
  PERIOD_END // Fim do quarto/período
  OVERTIME_START // Início da prorrogação
  GAME_START // Início da partida
  GAME_END // Fim da partida
}

// [E] Qual lado do placar um evento pertence.
enum TeamSide {
  HOME // Time mandante
  AWAY // Time visitante
}

enum CheckInMethod {
  QR_SCAN
  MANUAL_ADMIN
}

// ---------------------------------------------------------------------------
// 1.5 MVP e Inscrições
// ---------------------------------------------------------------------------

// [C] Fonte do prêmio de MVP — distingue cálculo automático de votação manual.
// STATS: calculado automaticamente via P-VAL em torneio oficial com mesário.
// INSTAGRAM: votação pública na enquete do Instagram, importado manualmente pelo admin.
// ADMIN: escolha manual pelo admin (fallback para casos especiais).
enum MvpSource {
  STATS // P-VAL calculado a partir de MatchStat (torneio oficial)
  INSTAGRAM // Enquete pública do Instagram (pelada / torneio comunitário)
  ADMIN // Escolha manual do administrador
}

// [F] Status do ciclo de vida de uma inscrição em evento.
enum RegistrationStatus {
  PENDING // Aguardando análise pelo administrador
  APPROVED // Inscrição aprovada — time confirmado no evento
  REJECTED // Inscrição rejeitada (motivo em notes)
  WAITLIST // Lista de espera — aguardando vaga
}

// ---------------------------------------------------------------------------
// 1.6 Premiações
// ---------------------------------------------------------------------------

// [L] Tipos de prêmio da temporada. COMMUNITY_IMPACT é específico do contexto
// social do projeto — reconhece contribuição para ações beneficentes.
enum AwardType {
  SEASON_MVP // MVP da temporada inteira
  SPLIT_MVP // MVP de um split específico
  TOP_SCORER // Artilheiro (maior média de pontos)
  BEST_DEFENDER // Melhor defensor (bloqueios + roubos)
  BEST_REBOUNDER // Melhor reboteiro
  BEST_ASSIST // Melhor passador
  BEST_NEWCOMER // Revelação da temporada
  SPORTSMANSHIP // Fair play / espírito esportivo
  COMMUNITY_IMPACT // Impacto social: engajamento em ações beneficentes
  CUSTOM // Prêmio personalizado (label obrigatório se CUSTOM)
}

// ---------------------------------------------------------------------------
// 1.7 Ação Social
// ---------------------------------------------------------------------------

// [I] Tipo de arrecadação da campanha beneficente.
enum DonationCategory {
  MONEY // Arrecadação financeira (R$)
  CLOTHES // Arrecadação de roupas e agasalhos
  FOOD // Arrecadação de alimentos não-perecíveis
  OTHER // Outros itens (especificado em itemDescription)
}

// [K] Ciclo de vida de uma doação individual.
// PLEDGED: o doador prometeu mas ainda não entregou.
// RECEIVED: item/valor recebido fisicamente no evento.
// CONFIRMED: confirmado pelo organizador e registrado na meta da campanha.
enum DonationStatus {
  PLEDGED // Prometido — aguardando entrega
  RECEIVED // Recebido fisicamente
  CONFIRMED // Confirmado e contabilizado na meta
}

// ---------------------------------------------------------------------------
// 1.8 Conteúdo
// ---------------------------------------------------------------------------

// [V] Novas categorias para cobrir o contexto social e recaps de eventos.
enum ArticleCategory {
  NEWS // Notícia geral
  INTERVIEW // Entrevista com jogador, presidente ou parceiro
  MATCH_REPORT // Relatório / análise pós-jogo
  OPINION // Opinião / coluna
  ANNOUNCEMENT // Comunicado oficial da liga
  FEATURE // Reportagem especial / perfil
  SOCIAL_ACTION // [V] Cobertura de ações beneficentes e impacto comunitário
  EVENT_RECAP // [V] Resumo de evento comunitário (além de partidas formais)
}

// ---------------------------------------------------------------------------
// 1.9 Jogadores e Times
// ---------------------------------------------------------------------------

enum SocialPlatform {
  INSTAGRAM
  TWITTER
  YOUTUBE
  TIKTOK
  TWITCH
  FACEBOOK
  LINKEDIN
}

enum Position {
  PG // Point Guard — Armador
  SG // Shooting Guard — Ala-Armador
  SF // Small Forward — Ala
  PF // Power Forward — Ala-Pivô
  C // Center — Pivô
}

enum PlayerStatus {
  ACTIVE // Ativo no elenco de algum time
  FREE_AGENT // Sem time, disponível para draft ou contratação
  INJURED // Lesionado — afastado temporariamente
  SUSPENDED // Suspenso — impedido de jogar por período definido
  RETIRED // Aposentado — encerrou a carreira
}

// ---------------------------------------------------------------------------
// 1.10 Draft
// ---------------------------------------------------------------------------

enum DraftStatus {
  UPCOMING // Agendado, inscrições ainda não abertas
  OPEN // Inscrições abertas para jogadores livres
  IN_PROGRESS // Draft acontecendo ao vivo
  COMPLETED // Concluído
}

// ---------------------------------------------------------------------------
// 1.11 Mídia
// ---------------------------------------------------------------------------

// Tipo de mídia. Mantido como enum para type-safety no backend e filtragem no frontend.
enum MediaType {
  VIDEO // Vídeo (highlights, melhores momentos, transmissões)
  IMAGE // Foto (fotos de jogo, evento, jogadores)
  GIF // GIF animado
}

// ---------------------------------------------------------------------------
// 1.12 Patrocinadores
// ---------------------------------------------------------------------------

enum SponsorLevel {
  TITLE // Master / naming rights (ex: "Liga Patrocinador X")
  GOLD // Ouro
  SILVER // Prata
  BRONZE // Bronze
  SUPPORTER // Apoiador / parceiro de menor tier
}

// ---------------------------------------------------------------------------
// 1.12 E-Commerce
// ---------------------------------------------------------------------------

enum OrderStatus {
  PENDING // Aguardando pagamento
  PAID // Pago — pagamento aprovado
  PROCESSING // Separando / preparando o pedido
  SHIPPED // Enviado — código de rastreio disponível
  DELIVERED // Entregue ao cliente
  CANCELED // Cancelado
  REFUNDED // Reembolsado
}

// [U] DONATION adicionado para doações monetárias feitas pela plataforma de loja.
// Isso permite que o fluxo Order → Payment seja reutilizado para campanhas.
enum OrderType {
  PRODUCT // Pedido de produtos físicos (camisas, acessórios)
  TICKET // Pedido de ingressos para uma partida
  DONATION // [U] Doação monetária para campanha beneficente
}

enum PaymentMethod {
  CREDIT_CARD
  DEBIT_CARD
  PIX
  BOLETO
}

enum PaymentStatus {
  PENDING // Aguardando confirmação do gateway
  APPROVED // Aprovado — pagamento confirmado
  FAILED // Falhou — pagamento recusado
  REFUNDED // Estornado ao cliente
}

enum TokenType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  TWO_FACTOR_CONFIRMATION
}

// ---------------------------------------------------------------------------
// 1.13 Privacidade e LGPD (Onda 2 - E2.6)
// ---------------------------------------------------------------------------
enum ConsentPurpose {
  ESSENTIAL // Operação básica (sempre obrigatório — base legal: execução de contrato)
  MARKETING_EMAIL // E-mails de newsletter e campanhas
  ANALYTICS // Coleta de métricas de uso
  PROFILE_PUBLIC // Exibir perfil público com estatísticas de jogador
  PHOTO_EVENTS // Aparecer em álbuns de eventos
  MINOR_PARENTAL // Consentimento dos responsáveis (jogadores <18)
  THIRD_PARTY_SHARE // Compartilhar dados com patrocinadores
}

// =============================================================================
// SEÇÃO 2: USUÁRIOS E CONTROLE DE ACESSO (RBAC)
// =============================================================================

// Model central do sistema. Todo acesso ao painel administrativo,
// às estatísticas e à loja passa por um User autenticado.
// REGRA: password deve ser sempre hash bcrypt/argon2 — nunca texto puro.
// REGRA: para desativar um usuário, use isActive = false. Nunca delete.
model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  password      String // Hash bcrypt/argon2 — NUNCA armazenar texto puro
  role          Role      @default(USER)
  avatarUrl     String?
  bio           String?   @db.Text
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  lastLoginAt   DateTime?

  // Campos para Autenticação em 2 Fatores
  isTwoFactorEnabled Boolean @default(false)
  twoFactorSecret    String? // Armazena a chave base32 do app autenticador

  // Mecanismo de Invalidação de Sessões (Camada C2)
  tokenVersion Int @default(0)

  player Player? // Relação 1:1 com o perfil de jogador

  // --- Relações ---
  orders            Order[]
  articles          Article[]
  comments          Comment[]
  articleLikes      ArticleLike[]
  tickets           Ticket[]
  notifications     Notification[]
  donations         Donation[] // Doações registradas por este usuário
  wishlistItems     WishlistItem[] // [N] Lista de desejos na loja
  productReviews    ProductReview[] // [O] Avaliações de produtos
  matchOfficials    MatchOfficial[] // [D] Partidas onde este user foi árbitro/mesário
  auditLogs         AuditLog[] // [Q] Ações administrativas deste usuário
  consents          Consent[] // [LGPD] Consentimentos concedidos pelo usuário
  performedCheckIns PlayerCheckIn[] @relation("PerformedCheckIns")

  // Relações nomeadas para MatchEvent (múltiplos FKs para User)
  recordedEvents MatchEvent[] @relation("EventRecorder") // [E] Eventos lançados como mesário
  voidedEvents   MatchEvent[] @relation("EventVoider") // [E] Eventos que este user anulou

  // Relação nomeada para MatchMvp (importação manual de resultado do Instagram)
  importedMvps MatchMvp[] @relation("MvpImporter") // [C] MVPs importados do Instagram

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Armazena tokens temporários de forma isolada e segura
model VerificationToken {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique
  type      TokenType
  expires   DateTime
  createdAt DateTime  @default(now())

  // Garante que não fiquem múltiplos tokens do mesmo tipo pendentes para o mesmo e-mail
  @@unique([email, type])
}

// =============================================================================
// MECANISMO DE REVOGAÇÃO DE TOKENS (BLACKLIST DA CAMADA C2)
// =============================================================================

model BlacklistedToken {
  id        String   @id @default(uuid())
  jti       String   @unique
  expiresAt DateTime // Permite limpar o banco de tokens que já venceram
  createdAt DateTime @default(now())

  // O índice em expiresAt acelera muito as queries de limpeza via Cron Job
  @@index([expiresAt])
}

// =============================================================================
// SEÇÃO 3: NOTIFICAÇÕES
// =============================================================================

// Notificações push/in-app para usuários.
// REGRA: readAt IS NULL = não lida. Nunca delete notificações — apenas marque como lida.
// O campo payload armazena dados extras em JSON para que o frontend redirecione
// ao recurso correto (ex: { "matchId": "...", "campaignId": "..." }).
model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  payload   Json? // Dados extras para deep link no app
  readAt    DateTime? // null = não lida
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}

// =============================================================================
// SEÇÃO 4: ESTRUTURA DA LIGA
// Hierarquia: Season → Split → Phase → Group → Match
//             Season → Split → PlayoffSeries → Match
// =============================================================================

// Season representa uma temporada completa (ex: "2025/26").
// Uma Season pode ter múltiplos Splits (etapas), como "Split 1", "Playoffs", etc.
// REGRA: múltiplas Seasons podem coexistir com isActive = true (torneios
// comunitários em paralelo). isActive é flag administrativa sem exclusividade.
model Season {
  id          String    @id @default(uuid())
  name        String // Ex: "Temporada 2025/26"
  slug        String    @unique // ★ NOVO — URL amigável: "copa-abril-2026"
  shortCode   String    @unique // ★ NOVO — Identificador curto: "CAB26" (3-8 chars)
  year        Int
  isActive    Boolean   @default(false)
  startDate   DateTime
  endDate     DateTime?
  description String?   @db.Text

  // --- Relações ---
  splits            Split[]
  drafts            Draft[]
  playerStats       PlayerSeasonStat[]
  leagueSponsors    LeagueSponsor[]
  teamSponsors      TeamSponsor[] // [W] Back-relation
  awards            SeasonAward[] // [L] Prêmios desta temporada
  freeAgentProfiles FreeAgentProfile[] // Jogadores candidatos ao draft desta temporada

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ★ NOVO — índice adicional para busca rápida por slug
  @@index([slug])
}

// Split é cada etapa ou sub-competição dentro de uma Season.
// Ex: "Split 1 — Fase Regular", "Copa de Inverno", "Playoffs Finais".
// defaultFormat indica a modalidade principal deste split.
// REGRA: múltiplos Splits podem coexistir com isActive = true, inclusive
// dentro da mesma Season (ex: "Fase Masculina" + "Fase Feminina" em paralelo).
model Split {
  id            String     @id @default(uuid())
  name          String // Ex: "Split 1", "Copa Abril 2025"
  type          SplitType
  defaultFormat GameFormat @default(FIVE_ON_FIVE) // [A] Modalidade padrão do split
  seasonId      String
  season        Season     @relation(fields: [seasonId], references: [id])
  startDate     DateTime
  endDate       DateTime?
  isActive      Boolean    @default(false)
  description   String?    @db.Text
  rulesUrl      String? // Link para regulamento em PDF ou página

  // --- Relações ---
  phases             Phase[]
  standings          Standing[]
  rosterSnapshots    RosterSnapshot[]
  playoffSeries      PlayoffSeries[]
  playerSplitStats   PlayerSplitStat[]
  eventRegistrations EventRegistration[] // [F] Times inscritos neste split
  campaigns          CharityCampaign[] // [J] Campanhas vinculadas a este split
  albums             EventAlbum[] // [P] Álbuns de fotos deste split
  awards             SeasonAward[] // [L] Prêmios de split
  contracts          PlayerContract[]
  checkIns           PlayerCheckIn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Cada Split é dividido em Fases (ex: Grupos → Quartas → Semi → Final).
model Phase {
  id      String    @id @default(uuid())
  name    String // Ex: "Fase de Grupos", "Quartas de Final"
  type    PhaseType
  splitId String
  split   Split     @relation(fields: [splitId], references: [id])
  order   Int // Ordem de disputa: 1 = primeira fase, 2 = segunda, etc.

  // --- Relações ---
  matches       Match[]
  groups        Group[]
  playoffSeries PlayoffSeries[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Grupo dentro de uma Fase (ex: "Grupo A", "Grupo Norte").
// Times são associados ao grupo via TeamGroup.
model Group {
  id      String @id @default(uuid())
  name    String // Ex: "Grupo A", "Grupo Norte"
  phaseId String
  phase   Phase  @relation(fields: [phaseId], references: [id])

  // --- Relações ---
  teamGroups TeamGroup[]
  standings  Standing[]
  matches    Match[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// PlayoffSeries representa uma série eliminatória entre dois times.
// Ex: Round 1 (Best-of-3), Semifinal (Best-of-5), Final (Best-of-7).
// REGRA: winnerId só é preenchido quando um time atingir requiredWins.
// O backend deve calcular isso a cada atualização de Match com status FINISHED.
model PlayoffSeries {
  id           String       @id @default(uuid())
  splitId      String
  split        Split        @relation(fields: [splitId], references: [id])
  phaseId      String
  phase        Phase        @relation(fields: [phaseId], references: [id])
  seriesNumber Int // Número da série dentro da fase (para montar o bracket)
  homeTeamId   String
  homeTeam     Team         @relation("SeriesHomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId   String
  awayTeam     Team         @relation("SeriesAwayTeam", fields: [awayTeamId], references: [id])
  homeWins     Int          @default(0)
  awayWins     Int          @default(0)
  requiredWins Int // 2 = Best-of-3 | 3 = Best-of-5 | 4 = Best-of-7
  status       SeriesStatus @default(SCHEDULED)
  winnerId     String?
  winner       Team?        @relation("SeriesWinner", fields: [winnerId], references: [id])

  // --- Relações ---
  matches Match[] // Todas as partidas desta série (gameNumberInSeries identifica a ordem)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([splitId, phaseId, seriesNumber])
}

// =============================================================================
// SEÇÃO 5: TIMES
// =============================================================================

// Time participante da liga. Pode ter múltiplas relações sociais, contratos,
// patrocinadores e produtos na loja.
// slug é usado para URLs amigáveis: /times/force-caxias
model Team {
  id                String  @id @default(uuid())
  name              String  @unique
  slug              String  @unique
  shortName         String? // Sigla de 3 letras: "FCX", "YNG"
  logoUrl           String?
  bannerUrl         String?
  primaryColor      String? // Hex: "#FF5722"
  secondaryColor    String?
  // Presidente ao estilo Kings League (pode ser um influenciador, ex-atleta, etc.)
  presidentName     String?
  presidentPhotoUrl String?
  description       String? @db.Text
  foundedYear       Int?
  homeVenueId       String? // Quadra principal do time (FK para Venue)
  homeVenue         Venue?  @relation("TeamHomeVenue", fields: [homeVenueId], references: [id])
  isActive          Boolean @default(true)

  // --- Relações ---
  socialLinks        TeamSocialLink[]
  contracts          PlayerContract[]
  homeMatches        Match[]             @relation("HomeTeam")
  awayMatches        Match[]             @relation("AwayTeam")
  standings          Standing[]
  teamGroups         TeamGroup[]
  products           Product[]
  sponsors           TeamSponsor[]
  draftPicks         DraftPick[]
  media              Media[]
  rosterSnapshots    RosterSnapshot[]
  eventRegistrations EventRegistration[] // [F] Inscrições em torneios
  awards             SeasonAward[] // [L] Prêmios coletivos do time
  // Relações nomeadas para PlayoffSeries
  homeSeriesTeam     PlayoffSeries[]     @relation("SeriesHomeTeam")
  awaySeriesTeam     PlayoffSeries[]     @relation("SeriesAwayTeam")
  wonSeries          PlayoffSeries[]     @relation("SeriesWinner")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Redes sociais do time. Estrutura idêntica à PlayerSocialLink.
model TeamSocialLink {
  id       String         @id @default(uuid())
  teamId   String
  team     Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  platform SocialPlatform
  url      String

  @@unique([teamId, platform])
}

// Tabela de associação N:M entre Time e Grupo.
model TeamGroup {
  teamId  String
  team    Team   @relation(fields: [teamId], references: [id])
  groupId String
  group   Group  @relation(fields: [groupId], references: [id])

  @@id([teamId, groupId])
}

// =============================================================================
// SEÇÃO 6: JOGADORES
// =============================================================================

// Jogador cadastrado na plataforma. Pode pertencer a um time via PlayerContract.
// rankingPoints e worldRanking são calculados via job agendado — não editar manualmente.
// slug é usado para URLs: /jogadores/joao-silva
model Player {
  id          String       @id @default(uuid())
  firstName   String
  lastName    String
  nickname    String?
  slug        String       @unique
  photoUrl    String?
  nationality String?      @default("Brasileiro")
  dateOfBirth DateTime?
  position    Position
  heightCm    Int?
  weightKg    Int?
  bio         String?      @db.Text
  status      PlayerStatus @default(ACTIVE)

  // Ranking individual — calculado via job agendado
  rankingPoints Float @default(0)
  worldRanking  Int?

  // Vínculo opcional com a conta de usuário (necessário para auto check-in e painel do jogador)
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  checkInQrCode        String?   @unique // "HEZI-PLAYER-{uuid}" — gerado server-side
  checkInQrGeneratedAt DateTime?

  // --- Relações ---
  socialLinks      PlayerSocialLink[]
  contracts        PlayerContract[]
  matchStats       MatchStat[]
  seasonStats      PlayerSeasonStat[]
  splitStats       PlayerSplitStat[]
  rankingHistory   PlayerRankingHistory[]
  draftPicks       DraftPick[]
  media            Media[]
  rosterSnapshots  RosterSnapshot[]
  freeAgentProfile FreeAgentProfile? // [G] Perfil de jogador livre para draft
  mvps             MatchMvp[] // [C] Partidas onde este jogador foi MVP
  matchEvents      MatchEvent[] // [E] Eventos de jogo onde este player é o ator
  awards           SeasonAward[] // [L] Prêmios individuais recebidos
  checkIns         PlayerCheckIn[]

  parentalConsentId String?  @unique // [LGPD] Consentimento dos responsáveis (jogadores <18)
  parentalConsent   Consent? @relation(fields: [parentalConsentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlayerCheckIn {
  id            String        @id @default(cuid())
  playerId      String
  player        Player        @relation(fields: [playerId], references: [id])
  matchId       String?
  match         Match?        @relation(fields: [matchId], references: [id])
  splitId       String?
  split         Split?        @relation(fields: [splitId], references: [id])
  checkedInAt   DateTime      @default(now())
  checkedInById String
  checkedInBy   User          @relation("PerformedCheckIns", fields: [checkedInById], references: [id])
  ip            String?
  method        CheckInMethod
  notes         String?

  @@unique([playerId, matchId])
  @@unique([playerId, splitId])
  @@index([matchId])
  @@index([splitId])
  @@index([checkedInAt])
}

// Redes sociais do jogador. Mesma estrutura de TeamSocialLink.
model PlayerSocialLink {
  id       String         @id @default(uuid())
  playerId String
  player   Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  platform SocialPlatform
  url      String

  @@unique([playerId, platform])
}

// Contrato (inscrição) do jogador em um time para um Split específico.
// REGRA: contrato ativo = endDate IS NULL. Invariante: no máximo 1 ativo por
// (playerId, splitId). Jogador pode ter contratos ativos em Splits diferentes
// simultaneamente (times diferentes em torneios paralelos).
// contractCode é gerado server-side, nunca vem do client.
model PlayerContract {
  id           String    @id @default(uuid())
  contractCode String    @unique // ★ NOVO — Código legível (ex: CON-GWARL10-CAB26-2604384729)
  playerId     String
  player       Player    @relation(fields: [playerId], references: [id])
  teamId       String
  team         Team      @relation(fields: [teamId], references: [id])
  splitId      String // ★ NOVO — Escopo do torneio
  split        Split     @relation(fields: [splitId], references: [id])
  jerseyNumber Int
  startDate    DateTime
  endDate      DateTime?
  // null = contrato vigente
  transferFee  Decimal?  @db.Decimal(10, 2)
  notes        String?
  // Observações sobre a transferência

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ★ NOVO — índice para a invariante: no máximo 1 contrato ativo por jogador por split
  @@index([playerId, splitId, endDate])
}

// Snapshot do elenco de um time no início de cada split.
// Resolve consultas históricas: "quem jogava no FCX no Split 1 de 2025?".
// REGRA: gerado automaticamente por job ao início de cada split, com base
// nos contratos ativos (endDate IS NULL). Não edite manualmente.
model RosterSnapshot {
  id           String   @id @default(uuid())
  splitId      String
  split        Split    @relation(fields: [splitId], references: [id])
  teamId       String
  team         Team     @relation(fields: [teamId], references: [id])
  playerId     String
  player       Player   @relation(fields: [playerId], references: [id])
  jerseyNumber Int // Número no momento do snapshot
  position     Position // Posição declarada no split

  createdAt DateTime @default(now())

  // Um jogador só pode aparecer em um time por split
  @@unique([splitId, playerId])
}

// Snapshot diário do ranking do jogador (via cron job).
// Permite exibir gráficos de evolução do ranking ao longo do tempo.
model PlayerRankingHistory {
  id            String   @id @default(uuid())
  playerId      String
  player        Player   @relation(fields: [playerId], references: [id])
  rankingPoints Float
  position      Int? // Posição no ranking geral naquele dia
  recordedAt    DateTime @default(now())

  @@index([playerId, recordedAt])
}

// [G] Perfil público de jogador livre — visível para times buscarem contratações.
// Inspirado no play.fiba3x3.com: qualquer jogador pode criar um perfil,
// indicar quais formatos quer jogar e ser encontrado para drafts ou peladas.
// REGRA: um jogador pode ter apenas um FreeAgentProfile ativo.
model FreeAgentProfile {
  id               String       @id @default(uuid())
  playerId         String       @unique
  player           Player       @relation(fields: [playerId], references: [id])
  bio              String?      @db.Text // Breve apresentação do jogador
  availableFrom    DateTime? // A partir de quando está disponível
  preferredFormats GameFormat[] // [A] Modalidades de interesse (array de enum)
  videoUrl         String? // Link de vídeo de apresentação (YouTube/Instagram)
  isVisible        Boolean      @default(true) // false = perfil oculto temporariamente
  // Se já candidato para um draft específico (FK para Season):
  draftSeasonId    String? // ID da Season cujo draft ele quer participar
  draftSeason      Season?      @relation(fields: [draftSeasonId], references: [id])
  notes            String?      @db.Text // Informações adicionais (ex: disponibilidade, restrições)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================================================
// SEÇÃO 7: DRAFT
// =============================================================================

// Draft ao vivo — estilo Kings League. Times escolhem jogadores em rodadas.
// streamUrl é o link da live (YouTube, Twitch, Instagram) onde o draft é transmitido.
model Draft {
  id           String      @id @default(uuid())
  name         String // Ex: "Draft Split 1 — 2025"
  seasonId     String
  season       Season      @relation(fields: [seasonId], references: [id])
  scheduledFor DateTime
  status       DraftStatus @default(UPCOMING)
  streamUrl    String? // Link da transmissão ao vivo
  description  String?     @db.Text

  // --- Relações ---
  picks DraftPick[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Registro de cada escolha no draft.
// pickNumber é o número global (1ª escolha geral, 2ª escolha geral...).
// originalTeamId rastreia trocas: se o FCX usou a pick do YNG, originalTeamId = YNG.id.
model DraftPick {
  id             String  @id @default(uuid())
  draftId        String
  draft          Draft   @relation(fields: [draftId], references: [id])
  teamId         String // Time que fez a escolha
  team           Team    @relation(fields: [teamId], references: [id])
  playerId       String
  player         Player  @relation(fields: [playerId], references: [id])
  round          Int // Rodada da escolha
  pickNumber     Int // Número global (1, 2, 3...)
  isKeeper       Boolean @default(false) // Jogador mantido da temporada anterior
  originalTeamId String? // Rastreia trocas de picks entre times

  createdAt DateTime @default(now())

  @@unique([draftId, pickNumber])
}

// =============================================================================
// SEÇÃO 8: LOCAIS (VENUE)
// =============================================================================

// Local onde as partidas são realizadas.
// [H] Adicionados: lat, lng (para mapa), surface (tipo de piso) e isIndoor.
// mapUrl é o link direto para o Google Maps — útil para divulgação de eventos.
model Venue {
  id       String  @id @default(uuid())
  name     String // Ex: "Quadra Poliesportiva da Associação", "Arena FCX"
  city     String
  state    String?
  country  String  @default("Brasil")
  address  String?
  capacity Int? // Capacidade de espectadores (se aplicável)
  imageUrl String? // Foto principal do local
  mapUrl   String? // Link Google Maps para divulgação

  // [H] Campos novos para filtros e exibição em mapa
  latitude  Float? // Latitude para exibição em mapa interativo
  longitude Float? // Longitude para exibição em mapa interativo
  surface   String? // Tipo de piso: "asfalto", "madeira", "sintético", "concreto"
  isIndoor  Boolean @default(false) // true = quadra coberta

  // --- Relações ---
  matches   Match[]
  photos    VenuePhoto[] // [H] Galeria de fotos do local
  homeTeams Team[]       @relation("TeamHomeVenue") // Times com esta quadra como casa

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// [H] Galeria de fotos do local — útil para que os times conheçam a quadra antes.
model VenuePhoto {
  id        String  @id @default(uuid())
  venueId   String
  venue     Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade)
  url       String
  caption   String?
  isPrimary Boolean @default(false)
  order     Int     @default(0)

  createdAt DateTime @default(now())
}

// =============================================================================
// SEÇÃO 9: INSCRIÇÃO EM EVENTOS
// =============================================================================

// [F] Inscrição de um time (formal ou ad-hoc) em um split ou partida específica.
// Inspirado no FIBA 3x3: qualquer grupo pode se inscrever, não só times cadastrados.
//
// REGRA: exatamente um dos campos (splitId, matchId) deve ser preenchido.
//        Validar no service antes de inserir.
// REGRA: se teamId for preenchido, o time já está cadastrado na plataforma.
//        Se não, usar campos adhoc* para capturar dados do grupo.
//
// Fluxo: grupo se inscreve → admin aprova → time é adicionado ao grupo/fase.
model EventRegistration {
  id String @id @default(uuid())

  // Onde está se inscrevendo (um dos dois deve ser preenchido):
  splitId String?
  split   Split?  @relation(fields: [splitId], references: [id])
  matchId String? // Para peladas de partida única (ex: "jogo beneficente 20/04")
  match   Match?  @relation(fields: [matchId], references: [id])

  // Time cadastrado na plataforma (OU time ad-hoc — nunca ambos):
  teamId String?
  team   Team?   @relation(fields: [teamId], references: [id])

  // Grupo ad-hoc (para peladas onde os participantes não têm time cadastrado):
  adhocTeamName String? // Nome do time improvisado
  contactName   String? // Nome do responsável
  contactPhone  String?
  contactEmail  String?
  adhocPlayers  Json? // Array JSON: [{"name":"João","position":"PG"}, ...]

  // Modalidade para a qual estão se inscrevendo:
  gameFormat GameFormat @default(FIVE_ON_FIVE)

  status          RegistrationStatus @default(PENDING)
  registrationFee Decimal?           @db.Decimal(10, 2)
  paidAt          DateTime? // Quando a taxa foi paga
  paymentRef      String? // Referência do pagamento externo (se aplicável)
  notes           String? // Observações do time ou do admin

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Um time cadastrado só pode se inscrever uma vez por split
  @@unique([splitId, teamId])
  @@index([status])
  @@index([splitId, status])
}

// =============================================================================
// SEÇÃO 10: PARTIDAS
// =============================================================================

// Model central de uma partida. Suporta todas as modalidades (1x1 a 5x5),
// torneios oficiais e peladas comunitárias.
//
// [A] format: modalidade da partida (1x1, 2x2, 3x3, 5x5)
// [A] isOfficial: true = torneio com mesário e estatísticas oficiais
//                 false = pelada/torneio comunitário (MVP por votação)
// [B] periods: placar por quarto/período (ver MatchPeriod)
// [C] mvp: prêmio de MVP da partida (ver MatchMvp)
// [D] officials: árbitros e mesários vinculados (ver MatchOfficial)
// [E] events: play-by-play digital (ver MatchEvent)
model Match {
  id           String      @id @default(uuid())
  title        String? // Ex: "Final do Split 1 — FCX vs YNG"
  scheduledFor DateTime
  status       MatchStatus @default(SCHEDULED)

  startedAt  DateTime? // ★ NOVO — Preenchido no startMatch
  finishedAt DateTime? // ★ NOVO — Preenchido no finishMatch

  // [A] Modalidade e caráter da partida
  format     GameFormat @default(FIVE_ON_FIVE) // 1x1, 2x2, 3x3, 5x5
  isOfficial Boolean    @default(true) // false = pelada — MVP vai para votação do Instagram

  // Posição na estrutura da liga (group ou series — nunca ambos)
  phaseId            String?
  phase              Phase?         @relation(fields: [phaseId], references: [id])
  groupId            String?
  group              Group?         @relation(fields: [groupId], references: [id])
  seriesId           String?
  series             PlayoffSeries? @relation(fields: [seriesId], references: [id])
  gameNumberInSeries Int? // Jogo 1, 2, 3... dentro da série de playoffs

  venueId String?
  venue   Venue?  @relation(fields: [venueId], references: [id])

  homeTeamId    String
  homeTeam      Team   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  homeScore     Int    @default(0)
  homeTeamFouls Int    @default(0) // Faltas de equipe — usado em overlay de transmissão ao vivo

  awayTeamId    String
  awayTeam      Team   @relation("AwayTeam", fields: [awayTeamId], references: [id])
  awayScore     Int    @default(0)
  awayTeamFouls Int    @default(0)

  winType         WinType? // Preenchido ao finalizar a partida
  durationMinutes Int? // Duração total em minutos

  streamUrl   String? // Link da transmissão ao vivo (YouTube, Instagram, Twitch)
  streamUrlBk String? // Link de transmissão de backup

  // --- Relações ---
  playerStats   MatchStat[]
  ticketBatches TicketBatch[]
  media         Media[]
  periods       MatchPeriod[] // [B] Placar por quarto/período
  mvp           MatchMvp? // [C] MVP da partida (1:1, opcional)
  officials     MatchOfficial[] // [D] Árbitros e mesários
  events        MatchEvent[] // [E] Play-by-play digital
  registrations EventRegistration[] // [F] Inscrições para esta partida específica
  campaigns     CharityCampaign[] // [J] Campanhas beneficentes vinculadas a esta partida
  albums        EventAlbum[] // [P] Álbuns de fotos desta partida
  checkIns      PlayerCheckIn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, scheduledFor])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@index([format, isOfficial])
}

// [B] Placar por quarto ou período de uma partida.
// 5x5: 4 quartos (periodNumber 1-4) + prorrogação (5+)
// 3x3: 1 período (periodNumber 1) + OT (2)
// 1x1 / 2x2: adaptar conforme regras do evento
// REGRA: criado automaticamente ao inicio de cada período pelo backend.
model MatchPeriod {
  id           String @id @default(uuid())
  matchId      String
  match        Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  periodNumber Int // 1=Q1, 2=Q2, 3=Q3, 4=Q4, 5+=OT
  homeScore    Int    @default(0)
  awayScore    Int    @default(0)
  durationSecs Int? // Duração real do período em segundos

  @@unique([matchId, periodNumber])
}

// [C] Prêmio de MVP de uma partida específica.
// Desacoplado de MatchStat para suportar duas fontes distintas:
// - STATS: calculado automaticamente pelo P-VAL em torneios oficiais
// - INSTAGRAM: votação pública, resultado importado manualmente pelo admin
// - ADMIN: escolha manual do administrador
//
// REGRA: isMvp em MatchStat deve ser sincronizado com este registro.
//        O backend deve atualizar ambos atomicamente (em uma transaction).
model MatchMvp {
  id       String    @id @default(uuid())
  matchId  String    @unique // 1:1 com Match — apenas um MVP por partida
  match    Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId String
  player   Player    @relation(fields: [playerId], references: [id])
  source   MvpSource // STATS, INSTAGRAM ou ADMIN

  // Campos específicos para MVP por votação do Instagram:
  instagramPollUrl  String? // Link da enquete do Instagram Stories/Post
  pollVotesTotal    Int? // Total de votos na enquete
  pollVotesPlayer   Int? // Votos que este jogador recebeu
  pollScreenshotUrl String? // Print do resultado para registro histórico

  // Rastreabilidade da importação manual:
  importedById String?
  importedBy   User?     @relation("MvpImporter", fields: [importedById], references: [id])
  importedAt   DateTime?

  createdAt DateTime @default(now())
}

// [D] Árbitros e mesários oficialmente vinculados a uma partida.
// Um mesário (SCOREKEEPER) com Role.SCOREKEEPER pode acessar o scorebook digital.
// REGRA: um usuário só pode ter um papel por partida.
model MatchOfficial {
  id      String       @id @default(uuid())
  matchId String
  match   Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId  String
  user    User         @relation(fields: [userId], references: [id])
  role    OfficialRole

  @@unique([matchId, userId, role])
}

// =============================================================================
// SEÇÃO 11: PLAY-BY-PLAY / SCOREBOOK DIGITAL
// =============================================================================

// [E] Registro atômico de cada lance de uma partida.
// Em torneios oficiais, o mesário (SCOREKEEPER) registra cada evento em tempo real.
// MatchStat é derivado automaticamente da agregação destes eventos.
//
// FLUXO: mesário lança MatchEvent → backend agrega → atualiza MatchStat + MatchPeriod
//        → publica via WebSocket para o placar ao vivo.
//
// CORREÇÃO: se o mesário errar, o evento pode ser anulado (isVoided = true).
//           Nunca delete um MatchEvent — mantenha o histórico com isVoided.
// REGRA: eventos de controle de jogo (PERIOD_START, GAME_END, etc.)
//        têm teamSide e playerId nulos.
model MatchEvent {
  id       String         @id @default(uuid())
  matchId  String
  match    Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type     MatchEventType
  teamSide TeamSide? // Qual time executou a ação (null para eventos de controle)
  playerId String? // Jogador que executou o lance (null para eventos de controle)
  player   Player?        @relation(fields: [playerId], references: [id])

  period      Int? // Quarto/período em que ocorreu (1, 2, 3, 4, 5=OT...)
  gameClockMs Int? // Milissegundos decorridos no período quando o evento ocorreu

  // Para eventos de pontuação: quantos pontos valem
  value Int? // 1 (lance livre), 2 (bandeja/mid-range), 3 (três pontos)

  note String? // Observação livre do mesário (ex: "buzzer beater", "dunk")

  // Mesário que registrou o evento
  recordedById String
  recordedBy   User   @relation("EventRecorder", fields: [recordedById], references: [id])

  // Anulação (correção de erro do mesário)
  isVoided   Boolean   @default(false)
  voidedAt   DateTime?
  voidedById String?
  voidedBy   User?     @relation("EventVoider", fields: [voidedById], references: [id])
  voidReason String? // Motivo da anulação para auditoria

  createdAt DateTime @default(now())

  @@index([matchId, period])
  @@index([matchId, playerId])
  @@index([matchId, isVoided])
  @@index([recordedById])
}

// =============================================================================
// SEÇÃO 12: ESTATÍSTICAS
// =============================================================================

// Estatísticas por partida (granular — uma linha por jogador/jogo).
// FONTE: gerada pelo backend ao agregar MatchEvents. Em peladas sem scorebook,
//        pode ser preenchida manualmente pelo admin.
//
// P-VAL (Player Value):
//   = (Pts × ShootingEfficiency) + Blocks + KeyAssists
//     + BuzzerBeaters + Drives + (Rebounds / 2) - Turnovers
//
// ShootingEfficiency = Points / FieldGoalsAttempted
// ATENÇÃO: verificar FieldGoalsAttempted > 0 antes de calcular. Armazenar NULL se zero.
model MatchStat {
  id       String @id @default(uuid())
  matchId  String
  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  // --- Estatísticas básicas ---
  points            Int @default(0)
  assists           Int @default(0)
  rebounds          Int @default(0) // Total (ofensivo + defensivo)
  offensiveRebounds Int @default(0)
  defensiveRebounds Int @default(0)
  steals            Int @default(0)
  blocks            Int @default(0) // Tocos
  turnovers         Int @default(0) // Erros / perdas de bola
  fouls             Int @default(0)
  minutesPlayed     Int @default(0)

  // --- Arremessos (para ShootingEfficiency) ---
  fieldGoalsMade         Int @default(0)
  fieldGoalsAttempted    Int @default(0)
  twoPointersMade        Int @default(0)
  twoPointersAttempted   Int @default(0)
  threePointersMade      Int @default(0)
  threePointersAttempted Int @default(0)
  freeThrowsMade         Int @default(0)
  freeThrowsAttempted    Int @default(0)

  // --- Highlight Stats (usados no P-VAL) ---
  dunks         Int @default(0) // DNK
  buzzerBeaters Int @default(0) // BZR — cesta no fim do tempo
  drives        Int @default(0) // DRV — penetrações para a cesta
  keyAssists    Int @default(0) // KAS — assistências que resultam em 2 ou 3 pts

  // --- Valores calculados pelo backend ---
  shootingEfficiency Float? // Pts / FGA (null se FGA = 0)
  playerValue        Float? // P-VAL calculado

  // isMvp: campo derivado — sincronizado com MatchMvp via transaction.
  // NUNCA editar manualmente: use MatchMvp como fonte de verdade.
  isMvp Boolean @default(false)

  @@unique([matchId, playerId])
  @@index([matchId])
  @@index([playerId])
}

// Estatísticas acumuladas por temporada (cache — gerado via job agendado).
// REGRA: não edite manualmente — recalcule via job ao final de cada rodada.
model PlayerSeasonStat {
  id       String @id @default(uuid())
  playerId String
  player   Player @relation(fields: [playerId], references: [id])
  seasonId String
  season   Season @relation(fields: [seasonId], references: [id])

  gamesPlayed Int @default(0)

  // Totais acumulados
  totalPoints        Int @default(0)
  totalAssists       Int @default(0)
  totalRebounds      Int @default(0)
  totalSteals        Int @default(0)
  totalBlocks        Int @default(0)
  totalTurnovers     Int @default(0)
  totalFouls         Int @default(0)
  totalMinutes       Int @default(0)
  totalDunks         Int @default(0)
  totalBuzzerBeaters Int @default(0)
  totalDrives        Int @default(0)
  totalKeyAssists    Int @default(0)

  // Médias por jogo
  avgPoints      Float  @default(0) // PPG
  avgAssists     Float  @default(0) // APG
  avgRebounds    Float  @default(0) // RPG
  avgBlocks      Float  @default(0) // BPG
  avgSteals      Float  @default(0) // SPG
  avgPlayerValue Float? // P-VAL médio

  // Percentuais de arremesso
  fieldGoalPct  Float? // FG%
  threePointPct Float? // 3P%
  freeThrowPct  Float? // FT%

  // Recordes pessoais na temporada
  bestGamePoints   Int @default(0)
  bestGameRebounds Int @default(0)
  bestGameAssists  Int @default(0)

  // Per 40 minutos — normalização para comparar jogadores com minutagens diferentes
  per40Points   Float?
  per40Assists  Float?
  per40Rebounds Float?

  @@unique([playerId, seasonId])
}

// Estatísticas acumuladas por split (granularidade abaixo da Season).
// Permite exibir abas como "2025-2026 Playoffs", "2025-2026 Split 1" no perfil.
// REGRA: gerado via job — não editar manualmente.
model PlayerSplitStat {
  id       String @id @default(uuid())
  playerId String
  player   Player @relation(fields: [playerId], references: [id])
  splitId  String
  split    Split  @relation(fields: [splitId], references: [id])

  gamesPlayed Int @default(0)

  totalPoints        Int @default(0)
  totalAssists       Int @default(0)
  totalRebounds      Int @default(0)
  totalSteals        Int @default(0)
  totalBlocks        Int @default(0)
  totalTurnovers     Int @default(0)
  totalFouls         Int @default(0)
  totalMinutes       Int @default(0)
  totalDunks         Int @default(0)
  totalBuzzerBeaters Int @default(0)
  totalDrives        Int @default(0)
  totalKeyAssists    Int @default(0)

  avgPoints      Float  @default(0)
  avgAssists     Float  @default(0)
  avgRebounds    Float  @default(0)
  avgBlocks      Float  @default(0)
  avgSteals      Float  @default(0)
  avgPlayerValue Float?

  fieldGoalPct  Float?
  threePointPct Float?
  freeThrowPct  Float?

  bestGamePoints   Int @default(0)
  bestGameRebounds Int @default(0)
  bestGameAssists  Int @default(0)

  per40Points   Float?
  per40Assists  Float?
  per40Rebounds Float?

  @@unique([playerId, splitId])
}

// =============================================================================
// SEÇÃO 13: CLASSIFICAÇÃO (TABELA DE PONTOS)
// =============================================================================

// Tabela de classificação de um time em um Split (tabela geral) ou Group (fase de grupos).
// REGRA: exatamente um de (splitId, groupId) deve ser preenchido. Nunca ambos.
//        Verificar no service antes de inserir.
// streak: "W3" = três vitórias seguidas | "L2" = duas derrotas seguidas.
//          Gerado no backend a partir dos resultados recentes.
//
// ATENÇÃO — NULL no PostgreSQL:
//   @@unique([teamId, splitId]) NÃO previne duplicatas quando splitId IS NULL,
//   pois NULL != NULL no SQL. O backend deve garantir a constraint via lógica de negócio.
model Standing {
  id     String @id @default(uuid())
  teamId String
  team   Team   @relation(fields: [teamId], references: [id])

  splitId String?
  split   Split?  @relation(fields: [splitId], references: [id])
  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id])

  position      Int
  gamesPlayed   Int     @default(0)
  wins          Int     @default(0)
  losses        Int     @default(0)
  points        Int     @default(0) // Pontos na tabela (ex: 2 por vitória, 0 por derrota)
  pointsFor     Int     @default(0) // Pontos marcados no total
  pointsAgainst Int     @default(0) // Pontos sofridos no total
  pointsDiff    Int     @default(0) // Saldo (pointsFor - pointsAgainst)
  streak        String? // "W3", "L2" — sequência atual de resultados

  updatedAt DateTime @updatedAt

  // Constraints separadas garantem unicidade dentro de Split e dentro de Group.
  @@unique([teamId, splitId])
  @@unique([teamId, groupId])
}

// =============================================================================
// SEÇÃO 14: PREMIAÇÕES
// =============================================================================

// [L] Prêmios concedidos no final de uma temporada ou split.
// Tanto jogadores individuais quanto times podem ser premiados.
// REGRA: se type = CUSTOM, o campo label é obrigatório (validar no service).
// REGRA: playerId e teamId são mutuamente exclusivos — exatamente um deve ser preenchido.
model SeasonAward {
  id       String    @id @default(uuid())
  seasonId String
  season   Season    @relation(fields: [seasonId], references: [id])
  splitId  String? // null = prêmio de toda a temporada | preenchido = prêmio de split
  split    Split?    @relation(fields: [splitId], references: [id])
  type     AwardType
  label    String? // Obrigatório se type = CUSTOM (ex: "Prêmio Coração de Leão")

  // Destinatário (jogador OU time — nunca ambos)
  playerId String?
  player   Player? @relation(fields: [playerId], references: [id])
  teamId   String?
  team     Team?   @relation(fields: [teamId], references: [id])

  description  String?   @db.Text // Justificativa do prêmio
  ceremonyDate DateTime? // Data da cerimônia de premiação

  createdAt DateTime @default(now())
}

// =============================================================================
// SEÇÃO 15: AÇÃO SOCIAL E BENEFICÊNCIA
// Esta seção é o coração do projeto: transforma a liga em agente de impacto
// comunitário. Rastreia campanhas, doações e as entidades beneficiadas.
// =============================================================================

// [I] Entidade beneficiada pelas campanhas (ONG, orfanato, comunidade, etc.).
// Um Beneficiary pode receber múltiplas campanhas ao longo do tempo.
model Beneficiary {
  id           String  @id @default(uuid())
  name         String // Ex: "Orfanato Lar Esperança", "ONG Raízes do Futuro"
  type         String // "orfanato", "ONG", "associação", "comunidade"
  description  String? @db.Text
  logoUrl      String?
  websiteUrl   String?
  contactName  String?
  contactEmail String?
  contactPhone String?
  address      String?
  city         String?
  isActive     Boolean @default(true)

  // --- Relações ---
  campaigns CharityCampaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// [J] Campanha de arrecadação de recursos para um beneficiário.
// Pode ser vinculada a um split (campanha da temporada) ou a uma partida
// específica (evento beneficente único), ou ser standalone.
//
// Para category = MONEY: rastrear goalAmount / raisedAmount (em R$).
// Para category = CLOTHES/FOOD/OTHER: rastrear goalQuantity / raisedQuantity (em itens).
//
// REGRA: splitId e matchId podem coexistir (ex: campanha do split com evento
//        especial em uma partida). Ambos podem ser null se a campanha for standalone.
model CharityCampaign {
  id          String           @id @default(uuid())
  title       String // Ex: "Agasalho Solidário — Inverno 2025"
  description String           @db.Text
  category    DonationCategory
  isActive    Boolean          @default(true)
  startDate   DateTime
  endDate     DateTime?
  mediaUrl    String? // Banner/flyer da campanha

  // Metas (usar o par correto conforme category):
  goalAmount     Decimal? @db.Decimal(10, 2) // Meta em R$ (category = MONEY)
  raisedAmount   Decimal? @db.Decimal(10, 2) // Arrecadado em R$
  goalQuantity   Int? // Meta em itens (CLOTHES/FOOD/OTHER)
  raisedQuantity Int? // Itens arrecadados

  // Beneficiário da campanha:
  beneficiaryId String
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id])

  // Contexto da campanha (opcionais — pode ser standalone):
  splitId String?
  split   Split?  @relation(fields: [splitId], references: [id])
  matchId String?
  match   Match?  @relation(fields: [matchId], references: [id])

  // --- Relações ---
  updates   CampaignUpdate[]
  donations Donation[]
  albums    EventAlbum[] // [P] Fotos do evento/campanha

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([beneficiaryId, isActive])
  @@index([splitId])
  @@index([matchId])
}

// [J] Atualização de progresso de uma campanha — publicada pelo admin.
// Exibida na página da campanha como feed de notícias.
// Ex: "Chegamos a 100 agasalhos! Obrigado a todos ❤️"
model CampaignUpdate {
  id         String          @id @default(uuid())
  campaignId String
  campaign   CharityCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  content    String          @db.Text
  imageUrl   String? // Foto do evento para ilustrar a atualização

  createdAt DateTime @default(now())
}

// [K] Registro individual de uma doação.
// Pode ser monetária (via Order/Payment) ou física (item entregue no evento).
//
// Para doações monetárias via plataforma:
//   orderId é preenchido, category = MONEY, amount = valor.
//
// Para doações físicas (roupas, alimentos):
//   orderId é null, category = CLOTHES/FOOD, itemDescription e quantity são usados.
//   O admin atualiza status de PLEDGED → RECEIVED → CONFIRMED manualmente.
//
// userId pode ser null para doações anônimas ou de não-cadastrados.
model Donation {
  id         String          @id @default(uuid())
  campaignId String
  campaign   CharityCampaign @relation(fields: [campaignId], references: [id])

  // Doador (pode ser anônimo):
  userId     String?
  user       User?   @relation(fields: [userId], references: [id])
  donorName  String? // Para doadores não cadastrados ou doações anônimas nomeadas
  donorEmail String? // Para confirmação por e-mail (não cadastrados)

  // Dados da doação:
  category        DonationCategory
  status          DonationStatus   @default(PLEDGED)
  amount          Decimal?         @db.Decimal(10, 2) // Para category = MONEY
  itemDescription String? // Para CLOTHES/FOOD/OTHER (ex: "10kg arroz")
  quantity        Int? // Quantidade de itens
  notes           String?

  // Rastreio de pagamento para doações monetárias online:
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  confirmedAt DateTime? // Quando o admin confirmou o recebimento
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([campaignId, status])
  @@index([userId])
}

// =============================================================================
// SEÇÃO 16: CONTEÚDO E NOTÍCIAS
// =============================================================================

// Artigo publicado no portal de notícias da liga.
// published = false permite salvar rascunhos antes de publicar.
// featured = true destaca o artigo na home da plataforma.
model Article {
  id          String          @id @default(uuid())
  title       String
  slug        String          @unique
  excerpt     String?         @db.Text // Resumo para cards e preview em redes sociais
  content     String          @db.Text
  coverImage  String?
  category    ArticleCategory @default(NEWS)
  published   Boolean         @default(false)
  publishedAt DateTime?
  featured    Boolean         @default(false)
  views       Int             @default(0)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  // --- Relações ---
  tags     ArticleTag[]
  comments Comment[]
  likes    ArticleLike[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([published, publishedAt])
  @@index([category])
}

model Tag {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  articles ArticleTag[]
}

// Tabela de associação N:M entre Article e Tag.
model ArticleTag {
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id])

  @@id([articleId, tagId])
}

// Comentários de usuários em artigos. Suporta respostas aninhadas (1 nível).
// isApproved = false por padrão — moderadores devem aprovar antes de exibir.
model Comment {
  id         String  @id @default(uuid())
  content    String  @db.Text
  articleId  String
  article    Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  authorId   String
  author     User    @relation(fields: [authorId], references: [id])
  isApproved Boolean @default(false)

  // Suporte a respostas aninhadas (máximo 1 nível de profundidade)
  parentId String?
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Curtidas em artigos — controle de duplicatas via chave composta.
model ArticleLike {
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, articleId])
}

// =============================================================================
// SEÇÃO 17: LOJA E E-COMMERCE
// =============================================================================

// Categoria de produtos da loja.
model ProductCategory {
  id          String  @id @default(uuid())
  name        String  @unique // "Camisetas", "Acessórios", "Bonés", "Calçados"
  slug        String  @unique
  description String?
  imageUrl    String?

  products Product[]
}

// Produto da loja. Pode ser do time (camisa oficial) ou da liga (merchandise geral).
// ATENÇÃO: usar Decimal para preço — nunca Float para valores monetários.
model Product {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  description String  @db.Text
  price       Decimal @db.Decimal(10, 2) // Preço base — nunca Float para dinheiro
  isActive    Boolean @default(true)
  featured    Boolean @default(false)

  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id])

  teamId String? // Produto específico de um time (ex: camisa do FCX)
  team   Team?   @relation(fields: [teamId], references: [id])

  // --- Relações ---
  images        ProductImage[]
  variants      ProductVariant[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[] // [N] Usuários que têm este produto na lista de desejos
  reviews       ProductReview[] // [O] Avaliações de clientes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  isPrimary Boolean @default(false)
  order     Int     @default(0)
}

// Variantes do produto (tamanho, cor, etc.).
// priceAdjust é um delta sobre o preço base (pode ser positivo ou negativo).
// ATENÇÃO — ARMADILHA DE NULL:
// @@unique([orderId, productId, variantId]) NÃO impede duplicatas quando variantId IS NULL.
// Trate no backend: ao adicionar item sem variante, faça upsert somando quantity.
model ProductVariant {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku         String   @unique // Código interno único (ex: "FCX-CAMISA-M-PRETA")
  size        String? // "PP", "P", "M", "G", "GG", "XGG"
  color       String?
  stock       Int      @default(0)
  priceAdjust Decimal? @db.Decimal(10, 2) // Delta sobre o preço base do produto

  orderItems OrderItem[]
}

// [N] Lista de desejos da loja — produtos salvos pelo usuário para comprar depois.
model WishlistItem {
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, productId])
}

// [O] Avaliação de produto pelo cliente — exibida na página do produto.
// isApproved = false por padrão — moderadores aprovam antes de exibir.
// REGRA: um usuário só pode avaliar cada produto uma vez.
model ProductReview {
  id         String  @id @default(uuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String
  user       User    @relation(fields: [userId], references: [id])
  rating     Int // 1 a 5 estrelas
  title      String?
  body       String? @db.Text
  isApproved Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, userId])
}

// [M] Cupom de desconto para a loja e ingressos.
// O campo couponCode em Order armazena o código como snapshot (mesmo se o cupom
// for desativado depois, o histórico do pedido fica íntegro).
// couponId é a FK para validação e controle de uso.
// REGRA: o backend deve verificar maxUses > usedCount antes de aplicar o cupom.
//        Usar transaction para incrementar usedCount e criar o Order atomicamente.
model Coupon {
  id            String    @id @default(uuid())
  code          String    @unique
  description   String?
  discountPct   Int? // Desconto percentual (ex: 10 = 10% OFF)
  discountFixed Decimal?  @db.Decimal(10, 2) // Desconto fixo em R$
  maxUses       Int? // null = ilimitado
  usedCount     Int       @default(0)
  validFrom     DateTime
  validUntil    DateTime?
  isActive      Boolean   @default(true)

  // --- Relações ---
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Pedido de compra — unifica loja (PRODUCT), ingressos (TICKET) e doações (DONATION).
// [U] OrderType.DONATION reutiliza o fluxo Order → Payment para doações monetárias.
// shippingAmount = 0 para pedidos de ingressos e doações.
model Order {
  id             String      @id @default(uuid())
  orderNumber    String      @unique @default(cuid()) // Legível para suporte (ex: "clxyz123")
  type           OrderType   @default(PRODUCT)
  totalAmount    Decimal     @db.Decimal(10, 2)
  shippingAmount Decimal     @default(0) @db.Decimal(10, 2)
  discountAmount Decimal     @default(0) @db.Decimal(10, 2)
  status         OrderStatus @default(PENDING)

  // Cupom de desconto aplicado:
  couponCode String? // Snapshot do código (preserva histórico)
  couponId   String? // FK para validação de uso
  coupon     Coupon? @relation(fields: [couponId], references: [id])

  notes String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Endereço de entrega (snapshot no momento da compra).
  // Para TICKET e DONATION, campos de shipping podem ser nulos.
  shippingName    String?
  shippingAddress String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  shippingCountry String? @default("Brasil")

  // --- Relações ---
  items     OrderItem[]
  payments  Payment[]
  tickets   Ticket[] // [G original] Ingressos gerados por este pedido
  donations Donation[] // [K] Doações monetárias feitas por este pedido

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Item de um pedido (produto ou variante específica).
// ATENÇÃO — ARMADILHA DE NULL:
// @@unique([orderId, productId, variantId]) não funciona quando variantId IS NULL.
// Usar upsert no backend ao adicionar item sem variante.
model OrderItem {
  id        String          @id @default(uuid())
  orderId   String
  order     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product         @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  quantity  Int
  unitPrice Decimal         @db.Decimal(10, 2) // Preço no momento da compra (snapshot)

  @@unique([orderId, productId, variantId])
}

// Registro de pagamento vinculado a um pedido.
// externalId é o ID do gateway de pagamento (Mercado Pago, Stripe, PagSeguro, etc.).
model Payment {
  id         String        @id @default(uuid())
  orderId    String
  order      Order         @relation(fields: [orderId], references: [id])
  amount     Decimal       @db.Decimal(10, 2)
  method     PaymentMethod
  status     PaymentStatus @default(PENDING)
  externalId String? // ID no gateway de pagamento
  paidAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================================================
// SEÇÃO 18: INGRESSOS / TICKETS
// =============================================================================

// Lote de ingressos para uma partida (ex: "Pista Geral", "Cadeira Numerada", "VIP").
// soldQuantity deve ser incrementado atomicamente pelo backend ao confirmar um pedido.
model TicketBatch {
  id            String    @id @default(uuid())
  matchId       String
  match         Match     @relation(fields: [matchId], references: [id])
  name          String // Ex: "Pista Geral", "Cadeira Numerada", "Camarote VIP"
  description   String?
  price         Decimal   @db.Decimal(10, 2)
  totalQuantity Int
  soldQuantity  Int       @default(0)
  maxPerUser    Int       @default(4) // Limite de ingressos por usuário neste lote
  isActive      Boolean   @default(true)
  saleStartsAt  DateTime?
  saleEndsAt    DateTime?

  tickets Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Ingresso individual gerado após pagamento aprovado.
// FLUXO: User → Order (type=TICKET) → Payment aprovado → Ticket criado.
// REGRA: qrCode gerado uma única vez (UUID) e nunca alterado.
//        Após isUsed = true, o ingresso não pode ser revalidado.
// holderName/holderDocument permitem que o comprador compre para outra pessoa.
model Ticket {
  id      String      @id @default(uuid())
  batchId String
  batch   TicketBatch @relation(fields: [batchId], references: [id])
  userId  String // Quem COMPROU (pode diferir do portador)
  user    User        @relation(fields: [userId], references: [id])
  orderId String? // Pedido que gerou este ingresso
  order   Order?      @relation(fields: [orderId], references: [id])

  // Portador nominal (opcional — para ingressos nominados ou VIP):
  holderName     String? // Nome de quem vai usar o ingresso
  holderDocument String? // CPF/RG do portador (para controle na entrada)

  qrCode String    @unique // UUID único para validação na catraca/entrada
  isUsed Boolean   @default(false)
  usedAt DateTime?
  price  Decimal   @db.Decimal(10, 2) // Preço pago no momento da compra (snapshot)

  createdAt DateTime @default(now())
}

// =============================================================================
// SEÇÃO 19: MÍDIA E ÁLBUNS
// =============================================================================

// Vídeos, imagens e GIFs associados a partidas, jogadores, times ou álbuns.
// albumId vincula a mídia a um EventAlbum para organização por evento.
model Media {
  id           String    @id @default(uuid())
  title        String
  type         MediaType // VIDEO, IMAGE ou GIF
  url          String
  thumbnailUrl String?
  description  String?
  duration     Int? // Duração em segundos (para vídeos)
  isFeatured   Boolean   @default(false)
  views        Int       @default(0)

  // Associações contextuais (todos opcionais):
  matchId  String?
  match    Match?  @relation(fields: [matchId], references: [id])
  playerId String?
  player   Player? @relation(fields: [playerId], references: [id])
  teamId   String?
  team     Team?   @relation(fields: [teamId], references: [id])

  // [P] Álbum ao qual esta mídia pertence:
  albumId String?
  album   EventAlbum? @relation(fields: [albumId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// [P] Álbum de fotos e vídeos de um evento, partida ou campanha.
// Permite organizar a mídia de um torneio ou ação social em uma galeria navegável.
// Pode estar vinculado a split, partida e/ou campanha simultaneamente.
model EventAlbum {
  id          String  @id @default(uuid())
  title       String // Ex: "Final do Split 1 — 12/04/2025", "Entrega de Agasalhos"
  description String?
  coverUrl    String? // Foto de capa do álbum
  isPublished Boolean @default(false)

  // Contextos do álbum (todos opcionais — pode ser standalone):
  splitId    String?
  split      Split?           @relation(fields: [splitId], references: [id])
  matchId    String?
  match      Match?           @relation(fields: [matchId], references: [id])
  campaignId String?
  campaign   CharityCampaign? @relation(fields: [campaignId], references: [id])

  // --- Relações ---
  media Media[] // Itens de mídia neste álbum

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================================================
// SEÇÃO 20: PATROCINADORES
// =============================================================================

// Patrocinador cadastrado. Pode patrocinar times (TeamSponsor) e/ou a liga inteira (LeagueSponsor).
model Sponsor {
  id           String       @id @default(uuid())
  name         String
  logoUrl      String?
  websiteUrl   String?
  level        SponsorLevel @default(SUPPORTER)
  isActive     Boolean      @default(true)
  startDate    DateTime?
  endDate      DateTime?
  contactName  String?
  contactEmail String?

  teamSponsors   TeamSponsor[]
  leagueSponsors LeagueSponsor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Patrocínio de um time específico em uma temporada.
// Um patrocinador pode patrocinar diferentes times em temporadas distintas.
// REGRA: o nível aqui (level) pode diferir do nível geral do patrocinador
//        (ex: um patrocinador SILVER pode ser GOLD para um time específico).
model TeamSponsor {
  id        String       @id @default(uuid())
  teamId    String
  team      Team         @relation(fields: [teamId], references: [id])
  sponsorId String
  sponsor   Sponsor      @relation(fields: [sponsorId], references: [id])
  level     SponsorLevel
  startDate DateTime
  endDate   DateTime?

  // Temporada do patrocínio (null = prazo indeterminado):
  seasonId String?
  season   Season? @relation(fields: [seasonId], references: [id])

  // ATENÇÃO — ARMADILHA DE NULL no PostgreSQL:
  // @@unique([teamId, sponsorId, seasonId]) NÃO impede duplicatas quando seasonId IS NULL,
  // pois NULL != NULL no SQL padrão. Para patrocínios sem temporada definida, o backend
  // deve verificar a existência do registro manualmente antes de inserir.
  @@unique([teamId, sponsorId, seasonId])
}

// Patrocínio institucional da liga inteira (não de um time específico).
// Ex: patrocinador TITLE do "Torneio Abril 2025", naming rights da temporada.
// context permite especificar o escopo: "All-Star Weekend", "Opening Night", null = toda a temporada.
model LeagueSponsor {
  id        String       @id @default(uuid())
  seasonId  String
  season    Season       @relation(fields: [seasonId], references: [id])
  sponsorId String
  sponsor   Sponsor      @relation(fields: [sponsorId], references: [id])
  level     SponsorLevel
  startDate DateTime
  endDate   DateTime?
  context   String? // Escopo: "Fase de Playoffs", "All-Star", null = toda a temporada

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([seasonId, sponsorId])
}

// =============================================================================
// SEÇÃO 21: AUDITORIA E LOGS ADMINISTRATIVOS
// =============================================================================

// [Q] Log imutável de todas as ações realizadas pelo painel administrativo.
// REGRA: NUNCA delete ou altere registros de AuditLog.
//        Campos before e after armazenam snapshots JSON do estado anterior e posterior.
// REGRA: usar @default(now()) — sem @updatedAt, pois o log é imutável.
//
// Exemplos de uso:
//   action: "UPDATE_MATCH_SCORE", entity: "Match", entityId: "<uuid>"
//   action: "IMPORT_INSTAGRAM_MVP", entity: "MatchMvp", entityId: "<uuid>"
//   action: "APPROVE_REGISTRATION", entity: "EventRegistration", entityId: "<uuid>"
model AuditLog {
  id       String  @id @default(uuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id])
  action   String // Verbo em SNAKE_CASE descrevendo a ação (ex: "DELETE_PLAYER")
  entity   String // Nome do model afetado (ex: "Player", "Match")
  entityId String // ID do registro afetado
  before   Json? // Estado anterior (null para criações)
  after    Json? // Estado novo (null para deleções)
  ip       String? // IP do usuário no momento da ação
  metadata Json? // Dados extras livres (ex: motivo da ação)

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId, createdAt])
  @@index([action])
}

// =============================================================================
// SEÇÃO 22: PRIVACIDADE E LGPD (Onda 2 - E2.6)
// =============================================================================

// Registro granular de consentimento do usuário para diferentes finalidades.
// Atende aos Artigos 7º, 8º e 9º da LGPD.
model Consent {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose   ConsentPurpose
  granted   Boolean // true = concedido, false = revogado
  grantedAt DateTime       @default(now())
  revokedAt DateTime?

  // Versão da política aceita no momento do consentimento
  policyVersion String

  // Dados forenses da concessão
  ipAddress String?
  userAgent String?

  // Jogador associado caso seja um consentimento parental
  player Player?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Apenas um registro por usuário e por finalidade. Atualizações mudam o 'granted'.
  @@unique([userId, purpose])
  @@index([userId])
  @@index([purpose, granted])
}
