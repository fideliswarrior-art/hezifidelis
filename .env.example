# ==============================================================================
# CONFIGURAÇÕES DA APLICAÇÃO
# ==============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Ambiente atual: "development" | "production" | "test"
NODE_ENV="development"

# ==============================================================================
# BANCO DE DADOS (PostgreSQL + Prisma)
# ==============================================================================
# URL de conexão usada pelo Prisma Client (geralmente com Connection Pooling via PgBouncer)
DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5432/NOME_DO_BANCO?schema=public"
# URL direta de conexão, usada apenas pelo Prisma Migrate (útil se estiver usando Supabase ou Neon)
DIRECT_URL="postgresql://USUARIO:SENHA@localhost:5432/NOME_DO_BANCO?schema=public"

# ==============================================================================
# SEGURANÇA E AUTENTICAÇÃO (JWT)
# ==============================================================================
# Para gerar uma chave ultra-segura, abra seu terminal e rode um destes comandos:
# 
# 👉 No Git Bash / Linux / Mac:
# openssl rand -base64 32
#
# 👉 No CMD / PowerShell (Windows):
# node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
#
JWT_SECRET="cole-aqui-a-chave-gerada-no-terminal"
JWT_REFRESH_SECRET="cole-aqui-outra-chave-diferente-gerada-no-terminal"

# ==============================================================================
# RATE LIMITING & CACHE (Upstash Redis)
# ==============================================================================
# Crie um banco de dados gratuito em: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL="https://seu-endpoint-aqui.upstash.io"
UPSTASH_REDIS_REST_TOKEN="seu-token-secreto-do-upstash-aqui"

# ==============================================================================
# SERVIÇO DE E-MAIL (SMTP via Gmail)
# ==============================================================================
# DICA: Use uma "Senha de App" do Google, nunca a senha real do seu e-mail!
# Como gerar: Conta do Google > Segurança > Verificação em duas etapas > Senhas de app
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="SEU-EMAIL@gmail.com"
SMTP_PASS="sua-senha-de-app-aqui"
EMAIL_FROM='"Hezi Fidelis" <SEU-EMAIL@gmail.com>'

# ==============================================================================
# [FUTURO] ARMAZENAMENTO DE IMAGENS (Fotos dos Jogadores e Times)
# ==============================================================================
# Exemplo de variáveis para AWS S3, Cloudflare R2 ou Supabase Storage
# STORAGE_BUCKET_NAME="hezi-assets"
# STORAGE_ACCESS_KEY="sua-access-key-aqui"
# STORAGE_SECRET_KEY="sua-secret-key-aqui"
# STORAGE_REGION="sa-east-1"

# ==============================================================================
# [FUTURO] PAGAMENTOS E ASSINATURAS
# ==============================================================================
# Variáveis preparadas para o seu Webhook em /api/webhooks/payment
# PAYMENT_SECRET_KEY="sk_test_sua-chave-secreta-do-gateway"
# PAYMENT_WEBHOOK_SECRET="whsec_assinatura-do-webhook-para-validacao"